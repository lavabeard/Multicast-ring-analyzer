{
  "name": "multicast-ring-analyzer",
  "version": "2.2.0",
  "description": "Multicast stream scanner — SAP discovery, ffprobe metadata, editable channel names, VLC launch",
  "main": "main.js",
  "author": "Alpha AV/IT",
  "license": "MIT",
  "scripts": {
    "start":      "electron .",
    "dist":       "electron-builder --linux --publish never",
    "dist:linux": "electron-builder --linux --publish never",
    "pack":       "electron-builder --dir   --publish never"
  },
  "dependencies": {},
  "devDependencies": {
    "electron":         "^30.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId":       "com.alpha.multicast-ring-analyzer",
    "productName": "Multicast Ring Analyzer",
    "copyright":   "Alpha AV/IT",
    "files": ["main.js", "preload.js", "index.html", "assets/"],
    "linux": {
      "target": ["AppImage", "deb"],
      "icon":   "assets/icon.png",
      "category": "Network",
      "description": "Discover and probe UDP multicast streams"
    }
  }
}
